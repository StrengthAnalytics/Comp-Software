# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase ---
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is server-only. Never expose to the client. Never log.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string, used only by the retained `db:*` scripts.
# Not part of the online-only workflow — development runs against the hosted project.
SUPABASE_DB_URL=

# --- Resend (Supabase SMTP provider for auth emails) ---
RESEND_API_KEY=

# --- Sentry ---
# DSN is safe to expose to the browser.
NEXT_PUBLIC_SENTRY_DSN=
# Build-time source map upload (CI/Vercel only).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Admin allowlist ---
# Comma-separated emails permitted to sign in and write. Server-only (no NEXT_PUBLIC_ prefix).
# These are the only accounts that should ever hold a session; keep public sign-ups disabled.
ADMIN_EMAILS=
