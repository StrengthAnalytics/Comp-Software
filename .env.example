# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase ---
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is server-only. Never expose to the client. Never log.
SUPABASE_SERVICE_ROLE_KEY=
# Local Postgres connection string used by `pnpm db:seed` (default points at local Supabase).
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Resend (Supabase SMTP provider for auth emails) ---
RESEND_API_KEY=

# --- Sentry ---
# DSN is safe to expose to the browser.
NEXT_PUBLIC_SENTRY_DSN=
# Build-time source map upload (CI/Vercel only).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Overlays ---
# Secret used to sign/verify per-comp overlay keys for OBS browser sources.
OVERLAY_SIGNING_SECRET=
